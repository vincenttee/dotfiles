[user]
    name = YOUR_NAME
    email = YOUR_EMAIL
    signingkey = YOUR_GPG_KEY_ID
[commit]
    gpgsign = true
[core]
    pager = diff-so-fancy | less --tabs=4 -RFX
    excludesfile = ~/.gitignore_global
[init]
    defaultBranch = main
[fetch]
    prune = true
[alias]
    # List all available aliases
    aliases = !git config --get-regexp 'alias.*' | colrm 1 6 | sed 's/[ ]/ = /' | sort

    # View the last commit with diff and stats
    last = log --stat -p -1 -U5

    # Commit as Work-In-Progress
    wip = commit -m "WIP"

    # Fetch and prune deleted remote branches
    prune = fetch --prune -v

    # Stash all changes including untracked files
    stash-all = stash save --include-untracked

    # One-line log of all branches
    logone = log --oneline --all --decorate

    # Detailed log with stats
    logstat = log --stat --all --decorate

    # Graph log with stats and pickaxe
    logstats = log --graph --oneline --stat --pickaxe-all

    # Pretty graph log with colors and author
    loggraph = log --graph --all --decorate --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'

    # List the 10 most recently modified branches
    recent = for-each-ref --count=10 --sort=-committerdate refs/heads/ --format="%(refname:short)"

    # Delete local branches that have been merged into main
    delete-merged-branches = "!git branch --merged | egrep -v '(^\\*|master|main|staging|demo|dev|wip)' | xargs git branch -d"

    # Delete remote branches that have been merged into origin/main
    delete-remote-merged-branches = "!git push origin --delete $(git branch -r --merged origin/main | grep origin | egrep -v '>|master|main|staging|demo|dev|wip' | cut -d/ -f2-)"

    # Show commit count summary by author
    stats = shortlog -sn

[color]
    branch = auto
    diff = auto
    grep = auto
    status = auto
[color "diff-highlight"]
    newHighlight = green bold 22
    newNormal = green bold
    oldHighlight = red bold 52
    oldNormal = red bold
[interactive]
    singlekey = true
[push]
    default = simple
[status]
    showUntrackedFiles = normal
[http "https://gopkg.in"]
    followRedirects = true

[includeIf "gitdir:~/PATH/TO/WORK/REPOS/"]
    path = ~/PATH/TO/WORK/.gitconfig
